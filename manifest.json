{
  "manifest_version": 3,
  "name": "HN Labels",
  "description": "Add persistent personal labels to Hacker News users.",
  "version": "0.1.0",
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "identity"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "405727967018-scek3k6aqvfkh3j5ks862tboa3di69eg.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.appdata"]
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "HN Labels",
    "default_popup": "src/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/*", "http://news.ycombinator.com/*"],
      "js": ["src/shared/data.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
